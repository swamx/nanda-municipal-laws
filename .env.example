MONGO_ATLAS_CONN_STR=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGODB_DB_NAME=mithackathon
CORS_ORIGINS=*

# Optional - see docs/DEPLOYMENT.md for details on each
MONGO_CONNECT_TIMEOUT_MS=5000
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
INGEST_API_KEY=
INGEST_MAX_URLS=10
RATE_LIMIT_PER_MINUTE=10
INGEST_RATE_LIMIT_PER_MINUTE=1
SEARCH_MODE=text_index
APP_VERSION=0.1.0
