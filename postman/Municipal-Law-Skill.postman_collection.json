{
  "info": {
    "name": "Municipal Law Skill for Autonomous Agents",
    "description": "Infra/integration test suite for the Municipal Law Skill API. Targets the live Vercel deployment by default (see the {{base_url}} collection variable, or use the Vercel/Local environment files in postman/environments/). Grounded in real, verified behavior against the full ingested NYC Administrative Code + NYC Health Code corpus - not invented expected values. See postman/README.md for how to run this with Newman.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "https://nanda-municipal-laws.vercel.app", "type": "string" },
    { "key": "document_id", "value": "", "type": "string" },
    { "key": "rate_limit_counter", "value": "0", "type": "string" }
  ],
  "item": [
    {
      "name": "1. Service Info",
      "item": [
        {
          "name": "GET / - root service info",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('name reflects rebrand', function () {",
                  "  pm.expect(body.name).to.eql('Municipal Law Skill for Autonomous Agents');",
                  "});",
                  "pm.test('links to /skill.md and /api/v1/health', function () {",
                  "  pm.expect(body.skill).to.eql('/skill.md');",
                  "  pm.expect(body.health).to.eql('/api/v1/health');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /skill.md - agent-facing reference",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/skill.md"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('content-type is text/plain', function () {",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('text/plain');",
                  "});",
