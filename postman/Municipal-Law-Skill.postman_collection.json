    {
      "name": "7. Ingest (manual/optional - do not run in automated CI)",
      "description": "POST /ingest triggers real outbound fetches and Atlas writes, and is rate-limited to 1 request/minute in its own bucket. Run this folder manually and deliberately, not as part of an automated suite - it's excluded from any 'Run whole collection' workflow you should wire into CI.",
      "item": [
        {
          "name": "Re-ingest a known-good Health Code article (idempotent)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"urls\": [\"https://www.nyc.gov/assets/doh/downloads/pdf/about/healthcode/health-code-article161.pdf\"]}"
            },
            "url": "{{base_url}}/api/v1/ingest"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Expect either 200 (ok, idempotent re-ingest) or 429 (if you've already",
                  "// used this minute's ingest quota) - both are acceptable outcomes here.",
                  "pm.test('status is 200 or 429', function () {",
                  "  pm.expect([200, 429]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.test('reports ok status for the URL', function () {",
                  "    pm.expect(body.results[0].status).to.eql('ok');",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "8. Rate Limiting (stress test - consumes your 10-req/min budget)",
      "description": "Self-looping request that calls /api/v1/health 11 times in a row using postman.setNextRequest(), asserting the first 10 succeed and the 11th returns 429 with a Retry-After header. Run this folder in isolation (Collection Runner, this folder only) - running it alongside other requests in the same minute will eat into their rate-limit budget too, and running the whole collection back-to-back may trigger this before you intend to test it.",
      "item": [
        {
          "name": "Rate Limit Probe (loops itself 11x)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/v1/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let count = parseInt(pm.collectionVariables.get('rate_limit_counter') || '0') + 1;",
                  "pm.collectionVariables.set('rate_limit_counter', count);",
                  "",
                  "if (count <= 10) {",
                  "  pm.test(`request ${count}/11 succeeds (200)`, function () {",
                  "    pm.response.to.have.status(200);",
                  "  });",
                  "} else {",
                  "  pm.test('request 11/11 is rate limited (429)', function () {",
                  "    pm.response.to.have.status(429);",
                  "  });",
                  "  pm.test('Retry-After header present', function () {",
                  "    pm.expect(pm.response.headers.has('Retry-After')).to.eql(true);",
                  "  });",
                  "}",
                  "",
                  "if (count < 11) {",
                  "  postman.setNextRequest('Rate Limit Probe (loops itself 11x)');",
                  "} else {",
                  "  postman.setNextRequest(null);",
                  "  pm.collectionVariables.set('rate_limit_counter', '0');",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
