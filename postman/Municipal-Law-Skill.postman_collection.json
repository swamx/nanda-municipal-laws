    {
      "name": "2. is_action_allowed (headline capability)",
      "item": [
        {
          "name": "Keep backyard chickens - absence-of-restriction, medium confidence",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"action\": \"Keep backyard chickens\"}"
            },
            "url": "{{base_url}}/api/v1/is_action_allowed"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('allowed is true (absence-of-restriction inference)', function () {",
                  "  pm.expect(body.allowed).to.eql(true);",
                  "});",
                  "pm.test('confidence is medium, not high (silence is a weaker claim)', function () {",
                  "  pm.expect(body.confidence).to.eql('medium');",
                  "});",
                  "pm.test('cites section 161.19', function () {",
                  "  pm.expect(body.citations[0].section_number).to.eql('161.19');",
                  "});",
                  "pm.test('surfaces the rooster prohibition as a condition, not a blocker', function () {",
                  "  pm.expect(body.conditions.join(' ').toLowerCase()).to.include('rooster');",
                  "});",
                  "pm.test('never fabricates the \"6 hens\" myth', function () {",
                  "  const allText = JSON.stringify(body).toLowerCase();",
                  "  pm.expect(allText).to.not.include('6 hens');",
                  "  pm.expect(allText).to.not.include('maximum');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Keep a rooster in my apartment - explicit prohibition, high confidence",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"action\": \"keep a rooster in my apartment\"}"
            },
            "url": "{{base_url}}/api/v1/is_action_allowed"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('allowed is false (explicit prohibition found)', function () {",
                  "  pm.expect(body.allowed).to.eql(false);",
                  "});",
                  "pm.test('cites section 161.19', function () {",
                  "  pm.expect(body.citations[0].section_number).to.eql('161.19');",
                  "});",
                  "pm.test('reasoning mentions the prohibition', function () {",
                  "  pm.expect(body.reasoning.toLowerCase()).to.include('rooster');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Unrelated action - unclear, never a guess from silence",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"action\": \"juggle flaming torches while unicycling on the moon\"}"
            },
            "url": "{{base_url}}/api/v1/is_action_allowed"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('allowed is null (unclear, no relevant provision found)', function () {",
                  "  pm.expect(body.allowed).to.eql(null);",
                  "});",
                  "pm.test('confidence is low', function () {",
                  "  pm.expect(body.confidence).to.eql('low');",
                  "});",
                  "pm.test('no citations fabricated', function () {",
                  "  pm.expect(body.citations).to.eql([]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "KNOWN LIMITATION - homonym keyword can select an irrelevant section",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"action\": \"launch a satellite into orbit from my roof\"}"
            },
            "url": "{{base_url}}/api/v1/is_action_allowed"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// This is a documented, known limitation (see docs/DATA_SOURCE.md), not a",
                  "// bug fix target: \"roof\" as a building material coincidentally matches an",
                  "// unrelated construction-code section for a query using \"roof\" as a rooftop",
                  "// location. We only assert the response is well-formed and never fabricates",
                  "// a citation - not that the determination is topically correct.",
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('confidence is never high for this kind of coincidental match', function () {",
                  "  pm.expect(body.confidence).to.not.eql('high');",
                  "});",
                  "pm.test('citation, if present, is a real section (never fabricated)', function () {",
                  "  if (body.citations.length > 0) {",
                  "    pm.expect(body.citations[0]).to.have.property('section_number');",
                  "    pm.expect(body.citations[0]).to.have.property('url');",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
